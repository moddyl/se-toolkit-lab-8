{
  "providers": {
    "custom": {
      "apiKey": "oauth",
      "apiBase": "http://127.0.0.1:42005/v1"
    }
  },
  "agents": {
    "defaults": {
      "provider": "custom",
      "model": "coder-model",
      "workspace": "./workspace"
    }
  },
  "tools": {
    "mcpServers": {
      "lms": {
        "command": "uv",
        "args": ["run", "python", "-m", "mcp_lms"],
        "env": {
          "NANOBOT_LMS_BACKEND_URL": "http://localhost:42002",
          "NANOBOT_LMS_API_KEY": "1234567890"
        }
      }
    }
  }
}
